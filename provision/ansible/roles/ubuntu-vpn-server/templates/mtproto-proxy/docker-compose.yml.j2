services:
  mtproto:
    image: telegrammessenger/proxy:latest
    pull_policy: always
    restart: always
    security_opt:
      - no-new-privileges:true
    ports:
      - "{{ vpn_tgproxy_mtproto_port_external | default(10443) }}:443/tcp"
    environment:
      SECRET: "{{ vpn_tgproxy_mtproto_secret }}"
{% if vpn_tgproxy_mtproto_tag | default('') | length > 0 %}
      TAG: "{{ vpn_tgproxy_mtproto_tag }}"
{% endif %}
    volumes:
      - /opt/mtproto-proxy/data:/data
